# ============================================================
# WealthTrack AU — Environment Variables
# Copy to .env and fill in your values before running.
# ============================================================

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
POSTGRES_USER=wealth_user
POSTGRES_PASSWORD=wealth_pass
POSTGRES_DB=wealth_tracker
DATABASE_URL=postgresql://wealth_user:wealth_pass@localhost:5432/wealth_tracker

# ---------------------------------------------------------------------------
# Backend
# ---------------------------------------------------------------------------
ENVIRONMENT=development

# ---------------------------------------------------------------------------
# Clerk — Authentication
# https://dashboard.clerk.com → API Keys
# ---------------------------------------------------------------------------
CLERK_SECRET_KEY=sk_test_...
CLERK_FRONTEND_API_URL=https://<your-instance>.clerk.accounts.dev
CLERK_WEBHOOK_SECRET=whsec_...

# ---------------------------------------------------------------------------
# Stripe — Billing
# https://dashboard.stripe.com → Developers → API Keys
# ---------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_ENTERPRISE_PRICE_ID=price_...

# ---------------------------------------------------------------------------
# Frontend (NEXT_PUBLIC_ prefix required for browser exposure)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
NEXT_PUBLIC_STRIPE_PRO_PRICE_ID=price_...
NEXT_PUBLIC_STRIPE_ENTERPRISE_PRICE_ID=price_...

# ---------------------------------------------------------------------------
# Market Data
# ---------------------------------------------------------------------------
COINGECKO_API_KEY=

# ---------------------------------------------------------------------------
# Error Monitoring (optional — leave blank to disable)
# ---------------------------------------------------------------------------
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# ---------------------------------------------------------------------------
# pgAdmin (Docker only)
# ---------------------------------------------------------------------------
PGADMIN_EMAIL=admin@wealth.local
PGADMIN_PASSWORD=admin
